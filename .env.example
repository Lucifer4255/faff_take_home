# LLM — set ONE of these keys. OpenRouter wins if both are set.
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# Model id — provider-specific format:
#   OpenRouter:       anthropic/claude-sonnet-4.5 (or any OpenRouter slug)
#   Anthropic direct: claude-sonnet-5
MODEL=anthropic/claude-sonnet-4.5

# Server (3123 by default — 3000 tends to collide with other dev servers)
PORT=3123

# Home-services browser-driver models (agentDrive.ts drives UC checkout to the
# "Proceed to pay" screen). Default is cheap + reliable; a failed drive escalates
# once to the fallback. Both are OpenRouter slugs (need OPENROUTER_API_KEY).
UC_DRIVER_MODEL=openrouter/google/gemini-2.5-flash
UC_DRIVER_MODEL_FALLBACK=openrouter/anthropic/claude-haiku-4.5
# UC_DRIVER_MAX_STEPS=45

# Per-target credentials are captured at runtime (browser-assisted auth) and
# stored OUTSIDE the repo — never commit session tokens.
